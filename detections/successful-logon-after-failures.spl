index=* source="XmlWinEventLog:Security" (EventID=4624 OR EventID=4625)
| eval src=if(IpAddress="-" OR isnull(IpAddress),"local",IpAddress)
| eval outcome=case(EventID=4625,"failure", EventID=4624,"success")
| stats count(eval(outcome="failure")) as failures count(eval(outcome="success")) as successes earliest(_time) as first_seen latest(_time) as last_seen by host TargetUserName src LogonType
| where failures >= 5 AND successes >= 1
| convert ctime(first_seen) ctime(last_seen)
| sort -failures
